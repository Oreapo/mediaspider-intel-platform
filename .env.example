# Local backend launcher and Compose host binding
MEDIASPIDER_BACKEND_HOST=127.0.0.1
MEDIASPIDER_BACKEND_PORT=8180
MEDIASPIDER_BACKEND_RELOAD=true
MEDIASPIDER_CORS_ORIGINS=http://127.0.0.1:5200,http://localhost:5200,http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:4173,http://localhost:4173,http://localhost:8080

# Storage
MEDIASPIDER_STORAGE_DIR=backend/storage
MEDIASPIDER_SQLITE_PATH=backend/storage/mediaspider-intel.sqlite3

# Repository mode: json or sqlite
MEDIASPIDER_REPOSITORY_MODE=sqlite
# Docker startup only migrates JSON when enabled and the SQLite file does not exist
MEDIASPIDER_AUTO_MIGRATE_JSON=false

# MediaCrawler integration
MEDIASPIDER_MEDIA_CRAWLER_ROOT=
MEDIASPIDER_MEDIA_CRAWLER_COMMAND=
# Used by docker-compose.crawler.yml as an additional build context
MEDIASPIDER_MEDIA_CRAWLER_HOST_PATH=

# Auth
MEDIASPIDER_AUTH_REQUIRED=false
MEDIASPIDER_AUTH_SECRET=change-me
MEDIASPIDER_AUTH_TOKEN_TTL_MINUTES=720
MEDIASPIDER_AUTH_USERS=admin:admin:admin:Administrator,analyst:analyst:analyst:Analyst

# Background scheduler
MEDIASPIDER_SCHEDULER_ENABLED=false
MEDIASPIDER_SCHEDULER_INTERVAL_SECONDS=60
MEDIASPIDER_SCHEDULER_EXECUTE_CRAWLER=true
MEDIASPIDER_TASK_MAX_CONCURRENT_RUNS=1
MEDIASPIDER_TASK_QUEUE_TIMEOUT_SECONDS=300
MEDIASPIDER_TASK_LEASE_SECONDS=30
# Optional stable identifier for multi-process lease observability.
MEDIASPIDER_INSTANCE_ID=
MEDIASPIDER_TASK_RECOVER_INTERRUPTED_RUNS=true

# Frontend
MEDIASPIDER_API_TARGET=http://127.0.0.1:8180
MEDIASPIDER_FRONTEND_PORT=5200
MEDIASPIDER_FRONTEND_URL=http://127.0.0.1:5200
VITE_API_BASE_URL=/api
